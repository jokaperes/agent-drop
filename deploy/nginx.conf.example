# Example reverse-proxy vhost. Serve only on your private network interface
# (Tailscale/VPN/LAN) — this app has no auth. Resolve the hostname via your
# private/split DNS (e.g. dnsmasq) to the machine's private IP.
server {
    listen 80;
    server_name drop.home;

    # Agent Drop — file exchange app. Allow large uploads.
    client_max_body_size 512m;

    location / {
        proxy_pass http://127.0.0.1:3010;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_http_version 1.1;
        proxy_request_buffering off;   # stream big uploads to disk
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
