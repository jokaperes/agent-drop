# Outbox watcher → ntfy push. Install to
# /etc/systemd/system/claude-drop-notify.service and adjust paths.
[Unit]
Description=Claude Drop outbox notifier (ntfy push on new files)
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/code/claude-drop
EnvironmentFile=/root/code/claude-drop/ntfy.env
ExecStart=/usr/local/bin/node /root/code/claude-drop/scripts/watch-outbox.mjs
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
