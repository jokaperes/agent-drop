# Push config for Agent Drop. Copy this to `ntfy.env` and fill it in.
# `ntfy.env` is gitignored because the topic acts as a shared push secret:
# anyone who knows it can publish to (and read) your notifications.

# ntfy server. The public instance is fine; self-host for full privacy.
NTFY_URL=https://ntfy.sh

# The topic your phone is subscribed to. Pick something long and unguessable.
NTFY_TOPIC=change-me-to-a-long-random-topic

# Optional bearer token if your ntfy server requires auth. Leave blank for none.
NTFY_TOKEN=

# URL shown in the push so a tap opens the app (your Tailscale/LAN host).
DROP_URL=http://drop.home

# Where the shared dropbox lives on disk (in/ = user→agent, out/ = agent→user).
DROPBOX_DIR=/root/agent-dropbox
